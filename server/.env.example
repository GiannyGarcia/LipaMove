PORT=3000
# Local dev: set MYSQL_* below. Railway: add MYSQL_URL=${{ MySQL.MYSQL_URL }} on the web service instead.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=lipamove
# MYSQL_SSL=true
# Basic in-memory auth rate limit
AUTH_RATE_LIMIT_MAX=12
AUTH_RATE_LIMIT_WINDOW_MS=900000
# Comma-separated allowlist for browser origins
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Socket.io: require valid session token on connect (recommended in production)
# SOCKET_AUTH_REQUIRED=true
# Optional: protect POST /api/puv/broadcast for IoT bridges (set a long random secret)
# INTERNAL_PUV_BROADCAST_KEY=
#
# Live PUV telemetry ingest (POST /api/puv/position) — devices send GPS here; server saves MySQL + Socket.io
# Set a long random string. Header: X-PUV-Ingest-Key: <value> or Authorization: Bearer <value>
# PUV_INGEST_KEY=
#
# Browser calls GET /api/fleet to merge data.xml with last MySQL positions (no secret).
# Snap PUV polylines from data.xml to real roads (OpenStreetMap graph via OSRM).
# OSRM_BASE_URL=https://router.project-osrm.org
# OSRM_MAX_WAYPOINTS=90
# Search radius (meters) per waypoint so points slightly off the road still snap onto it.
# OSRM_SNAP_RADIUS_METERS=200
# When one XML leg fails OSRM routing, bisect with midpoints (accuracy over speed).
# OSRM_LEG_SPLIT_DEPTH=9
# OSRM_LEG_MIN_SPLIT_KM=0.035
# DISABLE_ROAD_SNAP=true
# Optional Mapbox fallback when OSRM cannot complete a route (Directions API v5)
# MAPBOX_ACCESS_TOKEN=
# In-memory snap cache (routeService.js)
# ROUTE_CACHE_TTL_MS=86400000
# ROUTE_CACHE_MAX_ENTRIES=500
